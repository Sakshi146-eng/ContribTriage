.contribtriage/

# ── IDE & editors ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ── OS artefacts ─────────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
*~

# ── Secrets / environment configs ─────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.toml

# ── Node (if ever present in the analysed repo copies) ───────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ── Rust (cargo build artefacts) ─────────────────────────────────────────────
target/

# ── Go ────────────────────────────────────────────────────────────────────────
*.test
