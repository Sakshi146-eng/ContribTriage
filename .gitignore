# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Build & distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ── Testing artefacts ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pytype/
.pyre/

# ── Linting / formatting ──────────────────────────────────────────────────────
.ruff_cache/

# ── ContribTriage runtime output ──────────────────────────────────────────────
